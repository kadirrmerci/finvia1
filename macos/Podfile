platform :osx, '10.15'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'ephemeral', 'Flutter-Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure \"flutter pub get\" is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Flutter-Generated.xcconfig, then run \"flutter pub get\""
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_macos_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_macos_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

def allow_adhoc_firebase_auth_keychain(installer)
  original_mode = nil
  auth_keychain_file = File.join(
    installer.sandbox.root,
    'FirebaseAuth/FirebaseAuth/Sources/Swift/Storage/AuthKeychainServices.swift'
  )
  return unless File.exist?(auth_keychain_file)

  source = File.read(auth_keychain_file)
  marker = '#if !os(macOS) || !DEBUG'
  return if source.include?(marker)

  original = '    query[kSecUseDataProtectionKeychain as String] = true'
  replacement = <<~SWIFT.chomp
    #if !os(macOS) || !DEBUG
        query[kSecUseDataProtectionKeychain as String] = true
    #endif
  SWIFT

  unless source.include?(original)
    raise 'FirebaseAuth keychain implementation changed; update the macOS debug compatibility patch.'
  end

  original_mode = File.stat(auth_keychain_file).mode
  File.chmod(original_mode | 0200, auth_keychain_file)
  File.write(auth_keychain_file, source.sub(original, replacement))
ensure
  File.chmod(original_mode, auth_keychain_file) if original_mode
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_macos_build_settings(target)
  end
  allow_adhoc_firebase_auth_keychain(installer)
end
